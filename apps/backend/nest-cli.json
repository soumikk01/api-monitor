{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": false,
    "assets": [
      {
        "include": "generated/prisma/**/*",
        "exclude": "generated/prisma/**/*.node",
        "outDir": "./dist",
        "watchAssets": false
      }
    ]
  }
}
