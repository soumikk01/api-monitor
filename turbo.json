{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ],
      "cache": true
    },

    "dev": {
      "cache": false,
      "persistent": true
    },

    "dev:worker": {
      "cache": false,
      "persistent": true
    },

    "lint": {
      "outputs": [],
      "cache": true
    },

    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": [],
      "cache": true
    },

    "test": {
      "outputs": ["coverage/**"],
      "cache": true
    },

    "clean": {
      "cache": false
    }
  }
}
